<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.CarInfoAR" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowSplashScreenBackground">#FF000000</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#00000000</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
    </style>

    <style name="Theme.CarInfoAR.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FF0A0A0A</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_blank</item>
        <item name="postSplashScreenTheme">@style/Theme.CarInfoAR</item>
    </style>
</resources>
